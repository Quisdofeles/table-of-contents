    {
      "id": "tomato-basil-soup",
      "title": "Tomato Basil Soup",
      "bgImage": "images/TomatoBasilSoup.webp",
      "rating": 4,
      "tags": 
      [
        "Supper",
        "Main", 
        "Soup",
        "Fall",
        "Easy",
        "Stove Top",
        "American"
      ],
      "stats": 
      {
        "servings": "8 Servings",
        "time": "70 Min",
        "calories": "471 Cal/Ser",
        "difficulty": "Easy",
        "difficultyIcon": "images/Easy-Icon.webp"
      },
      "ingredients": 
      [
        {
          "section": "Soup",
          "items": 
          [
            "4 Tbsp. unsalted butter", 
            "1 large yellow onion, finely chopped", 
            "4 large carrots (about 1 1/4 lb. total), peeled, thinly sliced", 
            "Kosher salt",
            "Freshly ground black pepper",
            "1/3 cup tomato paste", 
            "1/2 tsp. Italian seasoning", 
            "1 (28-oz.) can whole plum tomatoes", 
            "3 1/2 cups low-sodium vegetable or chicken broth",
            "2 basil sprigs, plus 1/2 cup sliced fresh basil leaves",
            "1 cup heavy cream"
          ]
        },
        {
          "section": "Crostini",
          "items": 
          [
            "4 Tbsp. unsalted butter, softened",
            "2 oz. Parmesan, finely grated (about 1 cup), divided", 
            "Freshly ground black pepper",
            "1 baguette, cut into 1/2-thick slices",
            "Sliced fresh basil leaves, for serving"
          ]
        }
      ],
      "instructions": 
      [
        {
          "section": "Soup",
          "steps": 
          [
            "In a large saucepan over medium heat, melt butter. Add onion and carrots; season with salt and pepper. Cover and cook, stirring occasionally, until vegetables are softened, 7 to 8 minutes.", 
            "Add tomato paste and Italian seasoning. Cook, stirring, until tomato paste is brick red, 2 to 3 minutes. Add tomatoes and their juices, broth, and basil sprigs; season with salt and pepper. Crush tomatoes with a wooden spoon or potato masher. Reduce heat to medium and simmer, partially covered and stirring occasionally, until slightly thickened and reduced, about 25 minutes.",
            "Remove saucepan from heat. Discard basil sprigs. Stir in sliced basil. Using an immersion blender (or transfer mixture to a standard blender), blend until smooth (return to saucepan, if needed). Stir in cream; season with salt and pepper. Bring to a simmer over low heat and cook, stirring occasionally, until slightly thickened, about 10 minutes."
          ]
        },
        {
          "section": "Crostini",
          "steps": 
          [
            "Arrange a rack in center of oven; preheat to 400°. In a small bowl, mash butter and 1/4 cup Parmesan with a fork; season with pepper.", 
            "Spread some Parmesan butter on one side of each baguette slice, then transfer buttered side up to a parchment-lined baking sheet. Sprinkle with remaining 1/4 cup Parmesan.",
            "Toast crostini until edges are browned and cheese is melted, about 10 minutes.", 
            "Ladle soup into bowls. Top with basil. Serve with crostini alongside." 
          ]
        }
      ]
    },

