          "items": 
          [
            "2 tablespoons oil", 
            "1 pound ground beef", 
            "1 garlic clove, minced", 
            "1/3 onion, chopped",
            "2 tablespoon flour",
            "1 teaspoon salt",
            "1/2 teaspoon paprika",
            "1/2 cup water",
            "8 ounce sour cream",
            "10 ounce canned mushroom, pre-cut",
            "10 3/4 ounce cream of chiken soup, undiluted"
          ]
        }
      ],
      "instructions": 
      [
        {
          "section": "Stroganoff",
          "steps": 
          [
            "In a skillet, heat oil over medium-high heat.",
            "Saute beef, garlic, and onion.",
            "When onion is tender, reduce heat to low, stir in flour, salt, paprika. Cook 5 minutes.",
            "Stir in mushrooms, soup, and water. Simmer 10 minutes.",
            "Fold in sour cream, heat through but do not boil.",
            "Serve immediatly over rice or noodles."
